# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scripts (local scraping/utility scripts, not for deployment) — except committed guards
/scripts/*
!/scripts/check-links.mjs
!/scripts/check-affiliate-products.mjs
!/scripts/check-product-quality.mjs

# local SEO audit / private data exports — never commit or expose publicly
seo-audits/
search-console-exports/
analytics-exports/
imports/
private-imports/
affiliate-imports/
downloads/
*.crawl
*.seospider
# affiliate / data feed exports (app data lives in src/data/*.ts, never CSV)
*.csv
*.tsv
*.xlsx
*.xls
*.jsonl
